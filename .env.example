# Copy this file to .env and fill in real values before running in production
# For PostgreSQL (preferred):
DB_USER=your_db_user
DB_PASSWORD=GANTI_DENGAN_PASSWORD_POSTGRES_ANDA
DB_HOST=localhost
DB_PORT=5432
DB_NAME=GBR

# Or, for quick local development using SQLite, set DATABASE_URL like below:
# DATABASE_URL=sqlite:///./dev.db

# Optional DB settings
DB_CONNECT_TIMEOUT=10
DB_APP_NAME=python-apps-12R
DB_SSLMODE=

# Migration / runtime flags
DB_AUTO_MIGRATE=0
DB_CENTRAL_MODE=0
DB_CENTRAL_REQUIRE_SSL=1

# JWT and other secrets (fill as needed)
JWT_SECRET=replace_me
# Copy file ini menjadi .env lalu isi nilai sesuai PostgreSQL lokal Anda.
# Best practice: aplikasi memakai user khusus non-superuser, bukan akun postgres.

DB_USER=app_client
DB_PASSWORD=GANTI_DENGAN_PASSWORD_APP_DB
DB_HOST=192.168.1.10
DB_PORT=5432
DB_NAME=GBR
DB_AUTO_MIGRATE=0
DB_CONNECT_TIMEOUT=10
DB_APP_NAME=python-apps-12R
DB_CENTRAL_MODE=1
DB_CENTRAL_REQUIRE_SSL=1
DB_SSLMODE=require

# FastAPI backend reads DATABASE_URL first.
DATABASE_URL=postgresql+psycopg2://app_client:GANTI_DENGAN_PASSWORD_APP_DB@192.168.1.10:5432/GBR
JWT_SECRET_KEY=GANTI_DENGAN_SECRET_PANJANG_RANDOM
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Hanya untuk provisioning awal / maintenance admin (opsional, jangan dipakai oleh app runtime)
# DB_ADMIN_USER=postgres
# DB_ADMIN_PASSWORD=GANTI_PASSWORD_ADMIN_HANYA_SAAT_PROVISIONING

# Aktifkan hanya bila user runtime memang owner schema (tidak disarankan untuk production)
# DB_AUTO_MIGRATE=1
