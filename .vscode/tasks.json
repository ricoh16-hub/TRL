{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Alembic Current",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts/alembic_cli.py",
        "current"
      ],
      "problemMatcher": []
    },
    {
      "label": "Alembic Upgrade Head",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts/alembic_cli.py",
        "upgrade",
        "head"
      ],
      "problemMatcher": []
    },
    {
      "label": "Alembic Downgrade -1",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts/alembic_cli.py",
        "downgrade",
        "-1"
      ],
      "problemMatcher": []
    },
    {
      "label": "Alembic Revision Safe",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": [
        "scripts/alembic_cli.py",
        "revision",
        "--safe",
        "-m",
        "${input:alembicRevisionMessage}"
      ],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "alembicRevisionMessage",
      "type": "promptString",
      "description": "Pesan revision Alembic baru"
    }
  ]
}
